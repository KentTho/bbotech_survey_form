# ============================================================================
# SUPABASE (submit khảo sát CHÍNH — dùng ở API route server-side)
# ============================================================================
# Lấy từ Supabase Dashboard → Project Settings → API.
# CHỈ đặt ở server env (local .env / Vercel Environment Variables).
# TUYỆT ĐỐI KHÔNG đưa SERVICE_ROLE_KEY vào NEXT_PUBLIC hay client component.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================================
# GOOGLE SHEETS (DEPRECATED — không còn là submit chính kể từ Prompt 18)
# ============================================================================
# Giữ lại để tham khảo/backup thủ công. Submit khảo sát chính đã chuyển sang Supabase
# qua /api/survey/submit. KHÔNG cần set biến này trên Vercel nếu chỉ dùng Supabase.
NEXT_PUBLIC_GOOGLE_SHEETS_WEB_APP_URL=https://script.google.com/macros/s/XXXXXXXXXXXXXXXXXXXXXXXX/exec
