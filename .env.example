# ============================================================================
# NEON POSTGRESQL (submit khảo sát CHÍNH — dùng ở API route server-side)
# ============================================================================
# Lấy connection string từ Neon Dashboard → project → Connection Details (pooled).
# CHỈ đặt ở server env (local .env / Vercel Environment Variables).
# TUYỆT ĐỐI KHÔNG đưa vào NEXT_PUBLIC hay client component.
DATABASE_URL=

# ============================================================================
# SUPABASE (DEPRECATED — không còn dùng kể từ Prompt 19, đã chuyển sang Neon)
# ============================================================================
# Giữ trống/để tham khảo lịch sử. Code đã gỡ @supabase/supabase-js.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# ============================================================================
# GOOGLE SHEETS (DEPRECATED — không còn là submit chính kể từ Prompt 18)
# ============================================================================
# Backup thủ công. KHÔNG cần set trên Vercel.
# NEXT_PUBLIC_GOOGLE_SHEETS_WEB_APP_URL=https://script.google.com/macros/s/XXXXXXXXXXXXXXXXXXXXXXXX/exec
